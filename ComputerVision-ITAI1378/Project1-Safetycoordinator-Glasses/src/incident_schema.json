{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Automatic Incident Log",
  "description": "Schema for reporting safety hazards detected by the Anti-Gravity Safety Agent during a delivery.",
  "type": "object",
  "properties": {
    "incident_id": {
      "type": "string",
      "description": "Unique UUID for the incident record.",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "description": "ISO-8601 timestamp of when the hazard was detected or HUD alert was triggered.",
      "format": "date-time"
    },
    "driver_id": {
      "type": "string",
      "description": "Identifier for the smart glasses / driver."
    },
    "location": {
      "type": "object",
      "description": "GPS Coordinates of the hazard.",
      "properties": {
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
        "accuracy_meters": { "type": "number" }
      },
      "required": ["latitude", "longitude"]
    },
    "hazard_details": {
      "type": "object",
      "properties": {
        "hazard_type": {
          "type": "string",
          "enum": ["loose_pet", "broken_stairs", "uneven_pavement", "low_obstacle", "poor_visibility_icy", "improper_lifting_ergonomics", "other"]
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "critical"],
          "description": "Critical alerts trigger a Stop & Assess warning."
        },
        "description": {
          "type": "string",
          "description": "System generated description of the event."
        },
        "confidence_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "CV Model confidence score that triggered the alert."
        }
      },
      "required": ["hazard_type", "severity", "confidence_score"]
    },
    "media_evidence": {
      "type": "object",
      "description": "References to frame captures for the human Safety Coordinator to review.",
      "properties": {
        "screenshot_url": { "type": "string", "format": "uri" },
        "annotated_frame_url": { "type": "string", "format": "uri" }
      }
    }
  },
  "required": ["incident_id", "timestamp", "driver_id", "location", "hazard_details"]
}
